# Anthropic API Key (必需)
ANTHROPIC_API_KEY=sk-ant-xxx

# Model ID (可选，默认 claude-sonnet-4-20250514)
MODEL_ID=claude-sonnet-4-20250514

# 工作目录 (可选，默认当前目录)
WORKDIR=./workspace

# 日志级别 (可选，默认 INFO)
LOG_LEVEL=INFO

# 数据库路径 (可选，默认 ./data/agent.db)
DATABASE_PATH=./data/agent.db

# 最大循环次数 (可选，默认 100)
MAX_TURNS=100

# Token 预算 (可选，默认 200000)
TOKEN_BUDGET=200000
